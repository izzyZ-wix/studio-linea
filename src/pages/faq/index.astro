---
import Layout from "../../layouts/Layout.astro";
import JsonLd from "../../components/JsonLd.astro";
import { queryFaqItems } from "../../lib/faq";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { absoluteHref, faqPageJsonLd } from "../../utils/seo";

const faqItems = await queryFaqItems();
const faqPageUrl = Astro.site ? absoluteHref("/faq", Astro.site) : undefined;
const faqJsonLd =
  faqPageUrl && Astro.site
    ? faqPageJsonLd(faqItems, Astro.site, faqPageUrl)
    : null;
---

<Layout
  title="FAQ"
  description="Answers about Studio Linea shipping, care, returns, and warranty."
>
  {faqJsonLd && <JsonLd slot="head" data={faqJsonLd} />}
  <div class="max-w-6xl mx-auto px-lg py-4xl">
    <Breadcrumbs
      items={[
        { label: "Home", href: "/" },
        { label: "FAQ" },
      ]}
    />
    <header class="mb-3xl max-w-prose mt-md">
      <p class="font-body text-xs uppercase tracking-[0.2em] text-mute mb-md">
        Support
      </p>
      <h1 class="font-display text-4xl md:text-5xl leading-tight mb-lg">
        Frequently asked questions
      </h1>
      <p class="text-ink-soft leading-relaxed">
        Practical answers about ordering, delivery, and caring for your Studio Linea workspace.
      </p>
    </header>

    {faqItems.length > 0 ? (
      <section class="faq-section max-w-3xl">
        {faqItems.map((item) => (
          <details class="faq-item" id={item._id}>
            <summary class="faq-question">
              <span>{item.question}</span>
              <svg
                class="faq-toggle"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <polyline points="6 9 12 15 18 9" />
              </svg>
            </summary>
            <div class="faq-answer" set:html={item.answer} />
          </details>
        ))}
      </section>
    ) : (
      <p class="text-mute">No questions available yet.</p>
    )}
  </div>
</Layout>
