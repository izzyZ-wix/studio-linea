---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import CategoryRail from '../components/CategoryRail.astro';
import { productsV3 } from '@wix/stores';
import { listStoreCategories } from '../utils/categories';

let featured: any[] = [];
try {
  const { items: featuredProducts } = await productsV3
    .queryProducts({ fields: ['CURRENCY'] })
    .limit(4)
    .find();
  featured = (featuredProducts ?? []).filter((p) => p.ribbon?.name !== 'Gift Card');
} catch (err) {
  console.error('[home] featured products query failed:', err);
}

const storeCategories = await listStoreCategories();
---
<Layout>
  <section class="relative">
    <div class="max-w-6xl mx-auto px-lg py-4xl grid grid-cols-1 md:grid-cols-2 gap-3xl items-center">
      <div class="flex flex-col gap-lg">
        <h1 class="font-display text-4xl md:text-5xl leading-tight">A workspace, considered.</h1>
        <p class="text-lg text-mute max-w-prose">Desks, organizers, and acoustic pieces — curated as one calm, coherent environment.</p>
      </div>
      <div
        class="hero-image rounded-md"
        data-decorative-slot="hero"
        style="aspect-ratio: 4/5; background-color: var(--color-paper-warm);"
      >
        <!-- orchestrator injects <img src={decorativeImages.hero} …> here -->
      </div>
    </div>
  </section>
  <!-- home:stores -->
  <section class="py-4xl border-t border-rule">
    <div class="max-w-6xl mx-auto px-lg">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-lg mb-3xl">
        <div class="max-w-prose">
          <hr class="editorial-rule w-16 ml-0" />
          <p class="text-mute text-xs uppercase tracking-widest mt-md">The Collection</p>
          <h2 class="font-display text-3xl md:text-4xl leading-tight mt-sm">Pieces for the considered workspace</h2>
          <p class="text-ink-soft leading-relaxed mt-md">
            Desks, organizers, and acoustic pieces — curated as one calm, coherent environment.
          </p>
        </div>
        <a href="/products" class="btn btn-outline shrink-0" data-astro-prefetch="hover">View the collection</a>
      </div>
      {featured.length > 0 && (
        <div class="product-grid">
          {featured.map((product, idx) => (
            <ProductCard product={product} index={idx} />
          ))}
        </div>
      )}
    </div>
  </section>
  {storeCategories.length > 0 && (
    <section class="border-t border-rule">
      <div class="max-w-6xl mx-auto px-lg pt-3xl pb-lg">
        <p class="text-mute text-xs uppercase tracking-widest">Curated Spaces</p>
        <p class="text-ink-soft text-sm mt-sm max-w-prose">
          Explore arrangements composed as quiet, coherent environments.
        </p>
      </div>
      <CategoryRail
        categories={storeCategories}
        activeSlug={null}
        prevHref={null}
        nextHref={null}
      />
    </section>
  )}
  <!-- home:gift-cards -->
  <section class="max-w-6xl mx-auto px-lg py-4xl grid grid-cols-1 md:grid-cols-2 gap-3xl items-center">
    <div
      class="about-image rounded-md order-last md:order-first"
      data-decorative-slot="about"
      style="aspect-ratio: 4/3; background-color: var(--color-paper-warm);"
    >
      <!-- orchestrator injects <img src={decorativeImages.about} …> here -->
    </div>
    <div class="flex flex-col gap-md max-w-prose">
      <hr class="editorial-rule w-16 ml-0" />
      <h2 class="font-display text-3xl leading-tight">The story behind Studio Linea</h2>
      <p class="text-ink leading-relaxed">
        A short, brand-contextual paragraph about what makes Studio Linea distinct.
      </p>
      <p class="text-mute leading-relaxed">
        A second paragraph adding warmth and detail to the brand story.
      </p>
    </div>
  </section>
</Layout>
