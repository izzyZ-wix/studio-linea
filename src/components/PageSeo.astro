---
import { pageTitle, DEFAULT_OG_IMAGE, DEFAULT_OG_IMAGE_ALT } from "../utils/seo";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  ogType?: string;
}

const {
  title,
  description,
  image,
  imageAlt,
  noindex = false,
  ogType = "website",
} = Astro.props;

const fullTitle = pageTitle(title);
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site) : undefined;
const pageUrl = canonical ?? Astro.url;
const resolvedImage = image ?? (!noindex ? DEFAULT_OG_IMAGE : undefined);
const ogImage = resolvedImage && canonical
  ? new URL(resolvedImage, canonical)
  : resolvedImage
    ? new URL(resolvedImage, Astro.url)
    : undefined;
const resolvedImageAlt = imageAlt ?? (title ? `${title} — Studio Linea` : DEFAULT_OG_IMAGE_ALT);
---

{canonical && <link rel="canonical" href={canonical} />}
<link rel="alternate" hreflang="en" href={pageUrl} />
<link rel="alternate" hreflang="x-default" href={pageUrl} />

<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
{description && <meta name="description" content={description} />}
{noindex ? (
  <meta name="robots" content="noindex, follow" />
) : (
  <meta name="robots" content="index, follow, max-image-preview:large" />
)}

<meta property="og:locale" content="en_US" />
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content="Studio Linea" />
<meta property="og:url" content={pageUrl} />
<meta property="og:title" content={fullTitle} />
{description && <meta property="og:description" content={description} />}
{ogImage && <meta property="og:image" content={ogImage} />}
{ogImage && <meta property="og:image:width" content="1200" />}
{ogImage && <meta property="og:image:height" content="630" />}
{ogImage && <meta property="og:image:alt" content={resolvedImageAlt} />}

<meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
<meta name="twitter:url" content={pageUrl} />
<meta name="twitter:title" content={fullTitle} />
{description && <meta name="twitter:description" content={description} />}
{ogImage && <meta name="twitter:image" content={ogImage} />}
{ogImage && <meta name="twitter:image:alt" content={resolvedImageAlt} />}
